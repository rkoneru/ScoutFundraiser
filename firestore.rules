rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function membership(uid) {
      return get(/databases/$(database)/documents/memberships/$(uid));
    }

    function membershipExists(uid) {
      return exists(/databases/$(database)/documents/memberships/$(uid));
    }

    function userAccount(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userAccountExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function hasMembershipUnit(unitId) {
      return membershipExists(request.auth.uid)
        && membership(request.auth.uid).data.unitId == unitId;
    }

    function hasUserUnit(unitId) {
      return userAccountExists(request.auth.uid)
        && userAccount(request.auth.uid).data.unitId == unitId;
    }

    function isMemberOfUnit(unitId) {
      return isSignedIn()
        && (hasMembershipUnit(unitId) || hasUserUnit(unitId));
    }

    // SECURITY FIX: Normalize role comparison to prevent case variations bypassing checks
    function normalizeRole(role) {
      let normalized = role.lower().trim();
      return (normalized == 'unit_admin' || normalized == 'unit admin' || normalized == 'admin') ? 'admin'
        : (normalized == 'unit_leader' || normalized == 'unit leader' || normalized == 'leader') ? 'leader'
        : normalized;
    }

    function isUnitAdmin(unitId) {
      return isSignedIn()
        && ((hasMembershipUnit(unitId)
            && normalizeRole(membership(request.auth.uid).data.role) == 'admin')
          || (hasUserUnit(unitId)
            && normalizeRole(userAccount(request.auth.uid).data.role) == 'admin'));
    }

    function isUnitLeaderOrAdmin(unitId) {
      let role = hasMembershipUnit(unitId)
        ? normalizeRole(membership(request.auth.uid).data.role)
        : (hasUserUnit(unitId)
          ? normalizeRole(userAccount(request.auth.uid).data.role)
          : '');
      return isSignedIn() && (role == 'admin' || role == 'leader');
    }

    function isSameUnitAsUser(userId) {
      return isSignedIn()
        && ((membershipExists(request.auth.uid) && membershipExists(userId)
            && membership(request.auth.uid).data.unitId == membership(userId).data.unitId)
          || (membershipExists(request.auth.uid) && userAccountExists(userId)
            && membership(request.auth.uid).data.unitId == userAccount(userId).data.unitId)
          || (userAccountExists(request.auth.uid) && membershipExists(userId)
            && userAccount(request.auth.uid).data.unitId == membership(userId).data.unitId)
          || (userAccountExists(request.auth.uid) && userAccountExists(userId)
            && userAccount(request.auth.uid).data.unitId == userAccount(userId).data.unitId));
    }

    function isKnownUnit(unitId) {
      return unitId is string
        && unitId.size() > 0
        && exists(/databases/$(database)/documents/unitsPublic/$(unitId));
    }

    function isValidNormalizedRole(role) {
      let r = normalizeRole(role);
      return r == 'admin' || r == 'leader' || r == 'scout' || r == 'parent';
    }

    function isUnitCreator(unitId) {
      return unitId is string
        && exists(/databases/$(database)/documents/units/$(unitId))
        && get(/databases/$(database)/documents/units/$(unitId)).data.createdBy == request.auth.uid;
    }

    // Legacy compatibility: allow creating memberships that match an existing immutable users/{uid} role/unit.
    function matchesTrustedUserDoc(userId, unitId, role) {
      return userAccountExists(userId)
        && userAccount(userId).data.unitId == unitId
        && normalizeRole(userAccount(userId).data.role) == normalizeRole(role);
    }

    // Public unit lookup for pre-auth signup validation (stores minimal safe fields only).
    // Safe to be permissive: only public info, reads are open to all, deletes are blocked
    match /unitsPublic/{unitId} {
      allow get: if true;
      allow list: if false;
      // Allow any signed-in user to create (for recovery scenarios)
      allow create: if isSignedIn() && request.resource.data.unitId == unitId;
      // Allow original creator to update
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.createdBy;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Users can create their own account doc at signup.
      // Critical: role + unitId become immutable client-side to prevent privilege escalation.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isKnownUnit(request.resource.data.unitId)
        && isValidNormalizedRole(request.resource.data.role)
        && (
          // Only the unit creator may self-assign privileged roles.
          (normalizeRole(request.resource.data.role) == 'admin' || normalizeRole(request.resource.data.role) == 'leader')
            ? isUnitCreator(request.resource.data.unitId)
            : true
        );

      // Updates allowed, but role/unitId must not change.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.unitId == resource.data.unitId
        && normalizeRole(request.resource.data.role) == normalizeRole(resource.data.role);

      allow delete: if false;

      match /sales/{saleId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isSameUnitAsUser(userId));
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /scouts/{scoutId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isSameUnitAsUser(userId));
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /memberships/{userId} {
      // SECURITY FIX: Only allow reading memberships from your own unit (prevents IDOR enumeration)
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (membershipExists(request.auth.uid)
            && resource.data.unitId == membership(request.auth.uid).data.unitId)
      );
      // Membership creation is allowed for the signed-in user, but privileged roles are restricted.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && isKnownUnit(request.resource.data.unitId)
        && isValidNormalizedRole(request.resource.data.role)
        && (
          // Only unit creator can create leader/admin memberships.
          (normalizeRole(request.resource.data.role) == 'admin' || normalizeRole(request.resource.data.role) == 'leader')
            ? (isUnitCreator(request.resource.data.unitId) || matchesTrustedUserDoc(userId, request.resource.data.unitId, request.resource.data.role))
            : true
        );

      // Users may not change their own role/unit; unit admins may update roles within the unit.
      allow update: if isSignedIn()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.unitId == resource.data.unitId
        && isValidNormalizedRole(request.resource.data.role)
        && (
          // Self-update: role must not change
          (request.auth.uid == userId && normalizeRole(request.resource.data.role) == normalizeRole(resource.data.role))
          // Admin update: can change role but not unitId/userId
          || (isUnitAdmin(resource.data.unitId))
        );

      allow delete: if false;
    }

    match /profiles/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /units/{unitId} {
      // Unit doc contains private configuration; only unit members can read.
      // EXCEPTION: Allow unit creator to read for recovery purposes
      allow read: if isMemberOfUnit(unitId)
        || (isSignedIn() && exists(/databases/$(database)/documents/units/$(unitId))
            && get(/databases/$(database)/documents/units/$(unitId)).data.createdBy == request.auth.uid);
      // Allow signed-in user to create a unit they own.
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isUnitAdmin(unitId);

      match /scouts/{scoutId} {
        allow read: if isMemberOfUnit(unitId);
        allow create, update: if isUnitLeaderOrAdmin(unitId);
        allow delete: if isUnitAdmin(unitId);
      }

      match /products/{productId} {
        allow read: if isMemberOfUnit(unitId);
        // Allow creation by unit leaders/admins OR the unit creator (for initial setup)
        allow create: if isUnitLeaderOrAdmin(unitId) || isUnitCreator(unitId);
        allow update, delete: if isUnitLeaderOrAdmin(unitId);
      }

      match /orders/{orderId} {
        allow read: if isMemberOfUnit(unitId);
        allow create: if isUnitLeaderOrAdmin(unitId);
        allow update, delete: if isUnitLeaderOrAdmin(unitId);
      }
    }
  }
}
