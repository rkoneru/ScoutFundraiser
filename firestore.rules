rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function membership(uid) {
      return get(/databases/$(database)/documents/memberships/$(uid));
    }

    function membershipExists(uid) {
      return exists(/databases/$(database)/documents/memberships/$(uid));
    }

    function userAccount(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userAccountExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function hasMembershipUnit(unitId) {
      return membershipExists(request.auth.uid)
        && membership(request.auth.uid).data.unitId == unitId;
    }

    function hasUserUnit(unitId) {
      return userAccountExists(request.auth.uid)
        && userAccount(request.auth.uid).data.unitId == unitId;
    }

    function isMemberOfUnit(unitId) {
      return isSignedIn()
        && (hasMembershipUnit(unitId) || hasUserUnit(unitId));
    }

    // SECURITY FIX: Normalize role comparison to prevent case variations bypassing checks
    function normalizeRole(role) {
      let normalized = role.lower();
      return normalized == 'unit_admin' || normalized == 'unit admin' ? 'admin'
        : normalized == 'admin' ? 'admin'
        : normalized;
    }

    function isUnitAdmin(unitId) {
      return isSignedIn()
        && ((hasMembershipUnit(unitId)
            && normalizeRole(membership(request.auth.uid).data.role) == 'admin')
          || (hasUserUnit(unitId)
            && normalizeRole(userAccount(request.auth.uid).data.role) == 'admin'));
    }

    function isUnitLeaderOrAdmin(unitId) {
      let role = hasMembershipUnit(unitId)
        ? normalizeRole(membership(request.auth.uid).data.role)
        : (hasUserUnit(unitId)
          ? normalizeRole(userAccount(request.auth.uid).data.role)
          : '');
      return isSignedIn() && (role == 'admin' || role == 'leader');
    }

    function isSameUnitAsUser(userId) {
      return isSignedIn()
        && ((membershipExists(request.auth.uid) && membershipExists(userId)
            && membership(request.auth.uid).data.unitId == membership(userId).data.unitId)
          || (membershipExists(request.auth.uid) && userAccountExists(userId)
            && membership(request.auth.uid).data.unitId == userAccount(userId).data.unitId)
          || (userAccountExists(request.auth.uid) && membershipExists(userId)
            && userAccount(request.auth.uid).data.unitId == membership(userId).data.unitId)
          || (userAccountExists(request.auth.uid) && userAccountExists(userId)
            && userAccount(request.auth.uid).data.unitId == userAccount(userId).data.unitId));
    }

    // Public unit lookup for pre-auth signup validation (stores minimal safe fields only).
    match /unitsPublic/{unitId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.unitId == unitId
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /sales/{saleId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isSameUnitAsUser(userId));
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /scouts/{scoutId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isSameUnitAsUser(userId));
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /memberships/{userId} {
      // SECURITY FIX: Only allow reading memberships from your own unit (prevents IDOR enumeration)
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || (membershipExists(request.auth.uid)
            && resource.data.unitId == membership(request.auth.uid).data.unitId)
      );
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /units/{unitId} {
      // Unit doc contains private configuration; only unit members can read.
      allow read: if isMemberOfUnit(unitId);
      // Allow signed-in user to create a unit they own.
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isUnitAdmin(unitId);

      match /scouts/{scoutId} {
        allow read: if isMemberOfUnit(unitId);
        allow create, update: if isUnitLeaderOrAdmin(unitId);
        allow delete: if isUnitAdmin(unitId);
      }

      match /products/{productId} {
        allow read: if isMemberOfUnit(unitId);
        allow create, update, delete: if isUnitLeaderOrAdmin(unitId);
      }

      match /orders/{orderId} {
        allow read: if isMemberOfUnit(unitId);
        allow create: if isUnitLeaderOrAdmin(unitId);
        allow update, delete: if isUnitLeaderOrAdmin(unitId);
      }
    }
  }
}
